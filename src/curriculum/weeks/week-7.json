  "interviewQuestions": [
    {
      "id": "iq-w7-sql",
      "category": "SQL & Database",
      "questions": [
        {
          "id": "iq-w7-1",
          "question": "What is the difference between DBMS and RDBMS?",
          "answer": "DBMS stores data in files without relations. RDBMS stores data in tables with relationships using keys — MySQL, PostgreSQL are RDBMS."
        },
        {
          "id": "iq-w7-2",
          "question": "What is normalization?",
          "answer": "Process of organizing data to reduce redundancy — 1NF (atomic values), 2NF (no partial dependency), 3NF (no transitive dependency)."
        },
        {
          "id": "iq-w7-3",
          "question": "Difference between INNER JOIN and LEFT JOIN?",
          "answer": "INNER JOIN returns only matching rows from both tables. LEFT JOIN returns all rows from left table plus matching rows from right (NULL if no match)."
        }
      ]
    },
    {
      "id": "iq-w7-jdbc",
      "category": "JDBC",
      "questions": [
        {
          "id": "iq-w7-4",
          "question": "What is JDBC?",
          "answer": "Java Database Connectivity — API for connecting Java applications to relational databases using drivers, connections, statements, and result sets."
        },
        {
          "id": "iq-w7-5",
          "question": "Difference between Statement and PreparedStatement?",
          "answer": "Statement executes static SQL and is vulnerable to SQL injection. PreparedStatement uses parameterized queries — safer, faster for repeated execution."
        },
        {
          "id": "iq-w7-6",
          "question": "What is the DAO pattern?",
          "answer": "Data Access Object — separates business logic from database access. DAO classes encapsulate CRUD operations for a specific entity."
        }
      ]
    },
    {
      "id": "iq-w7-maven",
      "category": "Maven & Testing",
      "questions": [
        {
          "id": "iq-w7-7",
          "question": "What is Maven and why use it?",
          "answer": "Build automation and dependency management tool. Standardizes project structure, manages libraries via pom.xml, and handles compile/test/package lifecycle."
        },
        {
          "id": "iq-w7-8",
          "question": "What is JUnit used for?",
          "answer": "Unit testing framework for Java — write test methods with assertions to verify code behavior. Supports @BeforeEach, @AfterEach, and test lifecycle hooks."
        }
      ]
    }
  ],
