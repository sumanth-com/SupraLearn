  "interviewQuestions": [
    {
      "id": "iq-w5-collections",
      "category": "Collections",
      "questions": [
        {
          "id": "iq-w5-1",
          "question": "Difference between ArrayList and LinkedList?",
          "answer": "ArrayList uses dynamic array — O(1) random access, O(n) insert/delete. LinkedList uses nodes — O(1) insert/delete at ends, O(n) access."
        },
        {
          "id": "iq-w5-2",
          "question": "Difference between HashMap and HashTable?",
          "answer": "HashMap is not synchronized, allows one null key; HashTable is synchronized, no null keys/values."
        },
        {
          "id": "iq-w5-3",
          "question": "Difference between HashSet and TreeSet?",
          "answer": "HashSet uses hash table, no ordering, O(1) average. TreeSet uses red-black tree, sorted order, O(log n)."
        },
        {
          "id": "iq-w5-4",
          "question": "What is the difference between Comparable and Comparator?",
          "answer": "Comparable: natural ordering via compareTo() in the class. Comparator: external custom sorting via compare()."
        }
      ]
    },
    {
      "id": "iq-w5-java",
      "category": "Java",
      "questions": [
        {
          "id": "iq-w5-5",
          "question": "How does HashMap work internally?",
          "answer": "Uses array of buckets with hash function; collisions handled by linked list or tree (Java 8+)."
        },
        {
          "id": "iq-w5-6",
          "question": "What is Iterator?",
          "answer": "Interface to traverse collections without knowing internal structure; supports hasNext() and next()."
        }
      ]
    },
    {
      "id": "iq-w5-ai",
      "category": "AI",
      "questions": [
        {
          "id": "iq-w5-7",
          "question": "How can AI help choose the right collection?",
          "answer": "Analyze access patterns, insertion/deletion frequency, ordering needs, and suggest ArrayList vs LinkedList vs HashMap etc."
        },
        {
          "id": "iq-w5-8",
          "question": "What is Big O notation?",
          "answer": "Describes algorithm time/space complexity as input grows — e.g. O(1), O(n), O(log n), O(n²)."
        }
      ]
    }
  ],
