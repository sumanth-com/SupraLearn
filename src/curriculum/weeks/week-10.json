  "interviewQuestions": [
    {
      "id": "iq-w10-rest",
      "category": "REST & HTTP",
      "questions": [
        {
          "id": "iq-w10-1",
          "question": "What are the core REST constraints?",
          "answer": "Client-Server, Stateless, Cacheable, Uniform Interface, Layered System, Code on Demand (optional). These ensure scalability and separation of concerns."
        },
        {
          "id": "iq-w10-2",
          "question": "Difference between PUT and PATCH?",
          "answer": "PUT replaces the entire resource — send all fields. PATCH applies partial updates — send only changed fields."
        },
        {
          "id": "iq-w10-3",
          "question": "When to use 201 vs 200 vs 204?",
          "answer": "201 Created — resource created (POST). 200 OK — successful GET/PUT with body. 204 No Content — successful DELETE or update with no response body."
        }
      ]
    },
    {
      "id": "iq-w10-design",
      "category": "API Design",
      "questions": [
        {
          "id": "iq-w10-4",
          "question": "Why use DTOs instead of exposing entities?",
          "answer": "Decouples API contract from database schema, hides internal fields, prevents over-posting, and allows different request/response shapes."
        },
        {
          "id": "iq-w10-5",
          "question": "How do you implement pagination in REST APIs?",
          "answer": "Use query params like page, size, sort — return paginated response with totalElements, totalPages, and content array. Prefer page-based over offset for large datasets."
        },
        {
          "id": "iq-w10-6",
          "question": "What is API versioning and common strategies?",
          "answer": "URI versioning (/api/v1/), header versioning (Accept: application/vnd.api.v1+json), or query param. URI is most common and explicit."
        }
      ]
    },
    {
      "id": "iq-w10-security",
      "category": "API Security & Best Practices",
      "questions": [
        {
          "id": "iq-w10-7",
          "question": "What is CORS and why does it matter?",
          "answer": "Cross-Origin Resource Sharing — browser security that blocks requests from different origins unless server sends Access-Control-Allow-Origin headers."
        },
        {
          "id": "iq-w10-8",
          "question": "What is idempotency in REST APIs?",
          "answer": "Repeated identical requests produce the same result. GET, PUT, DELETE are idempotent. POST is not — use idempotency keys for safe retries."
        }
      ]
    }
  ],
