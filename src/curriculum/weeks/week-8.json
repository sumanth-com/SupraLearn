  "interviewQuestions": [
    {
      "id": "iq-w8-spring",
      "category": "Spring Boot",
      "questions": [
        {
          "id": "iq-w8-1",
          "question": "What is Spring Boot and why use it over plain Spring?",
          "answer": "Spring Boot auto-configures Spring applications with sensible defaults, embedded servers, and starter dependencies — reduces boilerplate and speeds up development."
        },
        {
          "id": "iq-w8-2",
          "question": "What is Dependency Injection?",
          "answer": "Design pattern where objects receive dependencies from an external source (IoC container) rather than creating them — promotes loose coupling and testability."
        },
        {
          "id": "iq-w8-3",
          "question": "Difference between @Controller and @RestController?",
          "answer": "@Controller returns view names for MVC. @RestController combines @Controller + @ResponseBody — returns data (JSON/XML) directly."
        }
      ]
    },
    {
      "id": "iq-w8-rest",
      "category": "REST API",
      "questions": [
        {
          "id": "iq-w8-4",
          "question": "What is REST?",
          "answer": "Representational State Transfer — architectural style using HTTP methods (GET, POST, PUT, DELETE) on resources identified by URLs, typically returning JSON."
        },
        {
          "id": "iq-w8-5",
          "question": "Difference between PUT and PATCH?",
          "answer": "PUT replaces the entire resource. PATCH applies partial updates to specific fields only."
        },
        {
          "id": "iq-w8-6",
          "question": "What HTTP status codes for CRUD?",
          "answer": "GET: 200 OK. POST (create): 201 Created. PUT/PATCH: 200 OK. DELETE: 204 No Content. Not found: 404. Bad input: 400."
        }
      ]
    },
    {
      "id": "iq-w8-jpa",
      "category": "Spring Data JPA",
      "questions": [
        {
          "id": "iq-w8-7",
          "question": "What is Spring Data JPA?",
          "answer": "Abstraction over JPA/Hibernate that provides repository interfaces with built-in CRUD methods — reduces boilerplate database code."
        },
        {
          "id": "iq-w8-8",
          "question": "Difference between CrudRepository and JpaRepository?",
          "answer": "CrudRepository provides basic CRUD. JpaRepository extends it with batch operations, flush, and JPA-specific methods like saveAndFlush()."
        }
      ]
    }
  ],
