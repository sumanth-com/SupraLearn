  "interviewQuestions": [
    {
      "id": "iq-w9-security",
      "category": "Security Fundamentals",
      "questions": [
        {
          "id": "iq-w9-1",
          "question": "Difference between Authentication and Authorization?",
          "answer": "Authentication verifies who you are (login). Authorization determines what you can access (permissions/roles) after authentication."
        },
        {
          "id": "iq-w9-2",
          "question": "What is JWT and how does it work?",
          "answer": "JSON Web Token — compact, signed token with Header, Payload, and Signature. Server generates it on login; client sends it in Authorization header for subsequent requests."
        },
        {
          "id": "iq-w9-3",
          "question": "JWT vs Session-based authentication?",
          "answer": "JWT is stateless — server doesn't store session. Sessions are stateful — server stores session data. JWT scales better for microservices; sessions are simpler for monoliths."
        }
      ]
    },
    {
      "id": "iq-w9-spring",
      "category": "Spring Security",
      "questions": [
        {
          "id": "iq-w9-4",
          "question": "What is the Security Filter Chain?",
          "answer": "Chain of filters in Spring Security that intercept requests — handles authentication, authorization, CSRF, and other security concerns before reaching the controller."
        },
        {
          "id": "iq-w9-5",
          "question": "What is BCrypt and why use it?",
          "answer": "Adaptive password hashing algorithm with built-in salt. Slow by design to resist brute-force attacks. Spring Security's recommended PasswordEncoder."
        },
        {
          "id": "iq-w9-6",
          "question": "What is RBAC?",
          "answer": "Role-Based Access Control — users are assigned roles (USER, ADMIN) and permissions are granted based on roles, not individual users."
        }
      ]
    },
    {
      "id": "iq-w9-api",
      "category": "API Security",
      "questions": [
        {
          "id": "iq-w9-7",
          "question": "HTTP 401 vs 403?",
          "answer": "401 Unauthorized — authentication failed or missing (not logged in). 403 Forbidden — authenticated but lacks permission for the resource."
        },
        {
          "id": "iq-w9-8",
          "question": "How do you secure a REST API with JWT?",
          "answer": "Configure Spring Security filter to validate JWT on each request, extract user/roles from token, enforce RBAC with @PreAuthorize, and never store secrets in code."
        }
      ]
    }
  ],
