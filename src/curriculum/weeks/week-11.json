  "interviewQuestions": [
    {
      "id": "iq-w11-design",
      "category": "Database Design",
      "questions": [
        {
          "id": "iq-w11-1",
          "question": "Difference between normalization and denormalization?",
          "answer": "Normalization reduces redundancy by splitting tables (1NF→3NF). Denormalization intentionally adds redundancy for read performance — used in analytics/reporting."
        },
        {
          "id": "iq-w11-2",
          "question": "Surrogate key vs natural key?",
          "answer": "Surrogate key is system-generated (auto-increment ID). Natural key exists in data (email, SSN). Surrogate keys are preferred for stability and simplicity."
        },
        {
          "id": "iq-w11-3",
          "question": "What is an ER diagram?",
          "answer": "Entity-Relationship diagram — visual model showing entities, attributes, relationships, and cardinality. Foundation for database schema design."
        }
      ]
    },
    {
      "id": "iq-w11-performance",
      "category": "Performance & SQL",
      "questions": [
        {
          "id": "iq-w11-4",
          "question": "How do indexes improve query performance?",
          "answer": "Indexes create sorted data structures (B-tree) allowing fast lookups without full table scans. Trade-off: faster reads, slower writes, extra storage."
        },
        {
          "id": "iq-w11-5",
          "question": "What is the N+1 query problem?",
          "answer": "Loading N entities triggers N additional queries for related data. Fix with fetch joins, entity graphs, or batch fetching in Hibernate/JPA."
        },
        {
          "id": "iq-w11-6",
          "question": "Difference between JPQL and native SQL?",
          "answer": "JPQL is object-oriented, database-independent, uses entity names. Native SQL uses actual table/column names, database-specific, useful for complex queries."
        }
      ]
    },
    {
      "id": "iq-w11-nosql",
      "category": "MongoDB & Best Practices",
      "questions": [
        {
          "id": "iq-w11-7",
          "question": "When to use MongoDB vs MySQL?",
          "answer": "MongoDB: flexible schema, nested documents, horizontal scaling, rapid iteration. MySQL: structured data, complex joins, ACID transactions, relational integrity."
        },
        {
          "id": "iq-w11-8",
          "question": "What is Flyway/Liquibase?",
          "answer": "Database migration tools — version-controlled schema changes applied automatically. Flyway uses SQL scripts; Liquibase supports XML/YAML/SQL with rollback support."
        }
      ]
    }
  ],
