      "questions": [
        {
          "id": "iq-w2-1",
          "question": "Difference between if-else and switch?",
          "answer": "if-else handles complex conditions and ranges; switch is cleaner for fixed discrete values."
        },
        {
          "id": "iq-w2-2",
          "question": "Difference between for, while, and do-while?",
          "answer": "for is count-controlled; while checks before loop; do-while executes at least once."
        },
        {
          "id": "iq-w2-3",
          "question": "What is method overloading?",
          "answer": "Same method name with different parameter lists in the same class."
        }
      ]
    },
