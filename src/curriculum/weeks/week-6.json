  "interviewQuestions": [
    {
      "id": "iq-w6-java8",
      "category": "Java 8",
      "questions": [
        {
          "id": "iq-w6-1",
          "question": "What is a Lambda Expression?",
          "answer": "Anonymous function implementing a functional interface — (params) -> expression or body."
        },
        {
          "id": "iq-w6-2",
          "question": "Difference between map() and flatMap()?",
          "answer": "map() transforms each element 1:1; flatMap() flattens nested structures (Stream of Streams to Stream)."
        },
        {
          "id": "iq-w6-3",
          "question": "What is Optional?",
          "answer": "Container that may or may not contain a value — avoids NullPointerException with safe API."
        }
      ]
    },
    {
      "id": "iq-w6-collections",
      "category": "Collections",
      "questions": [
        {
          "id": "iq-w6-4",
          "question": "Intermediate vs Terminal Stream operations?",
          "answer": "Intermediate (filter, map) return streams; terminal (collect, forEach) produce results and close the stream."
        }
      ]
    },
    {
      "id": "iq-w6-java",
      "category": "Java",
      "questions": [
        {
          "id": "iq-w6-5",
          "question": "Difference between Thread and Runnable?",
          "answer": "Thread is a class — extend and override run(). Runnable is an interface — implement run() and pass to Thread."
        },
        {
          "id": "iq-w6-6",
          "question": "What is synchronization?",
          "answer": "Mechanism to control access to shared resources by multiple threads — synchronized keyword or locks."
        },
        {
          "id": "iq-w6-7",
          "question": "What is ExecutorService?",
          "answer": "Higher-level API for managing thread pools — submit tasks without manually creating threads."
        }
      ]
    },
    {
      "id": "iq-w6-ai",
      "category": "AI",
      "questions": [
        {
          "id": "iq-w6-8",
          "question": "How can AI help refactor to Java 8?",
          "answer": "Convert loops to Streams, suggest Lambdas, explain pipelines, identify thread-safety issues — always verify output."
        }
      ]
    }
