  "interviewQuestions": [
    {
      "id": "iq-w3-oop",
      "category": "OOP",
      "questions": [
        {
          "id": "iq-w3-1",
          "question": "What is Object-Oriented Programming?",
          "answer": "A programming paradigm based on objects containing data (fields) and behavior (methods)."
        },
        {
          "id": "iq-w3-2",
          "question": "What is the difference between a class and an object?",
          "answer": "A class is a blueprint/template; an object is an instance of that class."
        },
        {
          "id": "iq-w3-3",
          "question": "What is encapsulation?",
          "answer": "Bundling data and methods together and restricting direct access using access modifiers (private fields + public getters/setters)."
        },
        {
          "id": "iq-w3-4",
          "question": "What is a constructor?",
          "answer": "A special method called when an object is created, used to initialize object state. Same name as class, no return type."
        },
        {
          "id": "iq-w3-5",
          "question": "Difference between static and instance variables?",
          "answer": "Static belongs to the class (shared); instance belongs to each object (unique per object)."
        }
      ]
    },
    {
      "id": "iq-w3-java",
      "category": "Java",
      "questions": [
        {
          "id": "iq-w3-6",
          "question": "What does the this keyword do?",
          "answer": "Refers to the current object instance — used to differentiate instance variables from parameters, call constructors, or return current object."
        },
        {
          "id": "iq-w3-7",
          "question": "Can we override a constructor?",
          "answer": "No. Constructors cannot be overridden, but can be overloaded."
        }
      ]
    },
    {
      "id": "iq-w3-ai",
      "category": "AI",
      "questions": [
        {
          "id": "iq-w3-8",
          "question": "How can AI help with OOP learning?",
          "answer": "Review class design, suggest naming, explain concepts, generate UML diagrams, and identify code smells — but you should design classes yourself first."
        }
      ]
    }
  ],
