  "interviewQuestions": [
    {
      "id": "iq-cat-java",
      "category": "Java",
      "questions": [
        {
          "id": "iq-1",
          "question": "What is Java?",
          "answer": "Java is a high-level, object-oriented programming language that runs on the JVM."
        },
        {
          "id": "iq-2",
          "question": "Difference between JDK, JRE, and JVM?",
          "answer": "JDK is the development kit, JRE is the runtime environment, JVM executes bytecode."
        },
        {
          "id": "iq-3",
          "question": "What are primitive data types in Java?",
          "answer": "byte, short, int, long, float, double, char, boolean."
        },
        {
          "id": "iq-4",
          "question": "What is the main method in Java?",
          "answer": "The entry point of a Java application: public static void main(String[] args)."
        }
      ]
    },
    {
      "id": "iq-cat-ai",
      "category": "AI",
      "questions": [
        {
          "id": "iq-5",
          "question": "What is an LLM?",
          "answer": "Large Language Model — AI trained on vast text data to understand and generate human language."
        },
        {
          "id": "iq-6",
          "question": "What is prompt engineering?",
          "answer": "Crafting effective inputs to get accurate, useful responses from AI models."
        },
        {
          "id": "iq-7",
          "question": "What are AI hallucinations?",
          "answer": "When AI generates confident but incorrect or fabricated information."
        },
        {
          "id": "iq-8",
          "question": "When should you not trust AI output?",
          "answer": "When learning core concepts, during exams, or without verifying against official documentation."
        }
      ]
    }
  ],
