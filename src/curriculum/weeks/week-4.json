  "interviewQuestions": [
    {
      "id": "iq-w4-oop",
      "category": "OOP",
      "questions": [
        {
          "id": "iq-w4-1",
          "question": "What is inheritance in Java?",
          "answer": "Mechanism where a child class acquires properties and behaviors of a parent class using extends keyword."
        },
        {
          "id": "iq-w4-2",
          "question": "Difference between method overloading and overriding?",
          "answer": "Overloading: same method name, different parameters (compile-time). Overriding: same signature in subclass (runtime)."
        },
        {
          "id": "iq-w4-3",
          "question": "What is polymorphism?",
          "answer": "Ability of an object to take many forms — compile-time (overloading) and runtime (overriding)."
        },
        {
          "id": "iq-w4-4",
          "question": "Abstract class vs Interface?",
          "answer": "Abstract class can have constructors and state; interface is a contract with abstract methods (Java 8+ default/static methods)."
        }
      ]
    },
    {
      "id": "iq-w4-java",
      "category": "Java",
      "questions": [
        {
          "id": "iq-w4-5",
          "question": "Checked vs Unchecked exceptions?",
          "answer": "Checked must be handled at compile time (IOException); unchecked extend RuntimeException (NullPointerException)."
        },
        {
          "id": "iq-w4-6",
          "question": "What is the finally block?",
          "answer": "Always executes after try/catch, used for cleanup regardless of exception."
        },
        {
          "id": "iq-w4-7",
          "question": "Difference between throw and throws?",
          "answer": "throw explicitly throws an exception; throws declares exceptions a method may throw."
        }
      ]
    },
    {
      "id": "iq-w4-ai",
      "category": "AI",
      "questions": [
        {
          "id": "iq-w4-8",
          "question": "How can AI help debug Java exceptions?",
          "answer": "Explain stack traces, identify root cause, suggest fixes — but always verify and understand the fix yourself."
        }
      ]
    }
  ],
